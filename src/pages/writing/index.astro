---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('writing')).sort((a, b) => {
  if (a.data.status === 'published' && b.data.status === 'published') {
    return (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0);
  }
  if (a.data.status !== b.data.status) return a.data.status === 'published' ? -1 : 1;
  return a.data.order - b.data.order;
});

const hasComingSoon = entries.some((e) => e.data.status === 'coming-soon');
---

<BaseLayout title="Writing — Teslim" active="writing">
  <h1>Writing</h1>
  <p class="role">Longer pieces — postmortems, architecture decisions, tradeoff analyses.</p>

  <div class="section-label">Articles</div>

  {entries.map((entry) => {
    const isPublished = entry.data.status === 'published';
    return (
      <div class="post">
        {isPublished && (
          <div class="post-date">
            {entry.data.date?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </div>
        )}
        {isPublished ? (
          <h3><a href={`/writing/${entry.id}/`}>{entry.data.title}</a></h3>
        ) : (
          <h3 class="coming-soon">{entry.data.title}</h3>
        )}
        <p class={isPublished ? undefined : 'coming-soon'}>{entry.data.summary}</p>
        {!isPublished && (
          <div class="tag-row"><span class="tag">coming soon</span></div>
        )}
      </div>
    );
  })}

  {hasComingSoon && (
    <p style="margin-top:32px; color: var(--muted); font-size:14.5px;">This list is intentionally short — these are coming soon, not published yet. New pieces show up here as they're written.</p>
  )}
</BaseLayout>
