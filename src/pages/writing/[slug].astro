---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const published = await getCollection('writing', ({ data }) => data.status === 'published');
  return published.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} — Teslim`} description={entry.data.summary} active="writing">
  <h1>{entry.data.title}</h1>
  <p class="role">
    {entry.data.date?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
  </p>
  <Content />
</BaseLayout>
