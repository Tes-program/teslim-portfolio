---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resume — Teslim" active="resume">
  <h1>Resume</h1>
  <p class="role">Backend Engineer — Payments &amp; Fintech Infrastructure</p>

  <p><a href="https://docs.google.com/document/d/e/2PACX-1vQEGgJJPgNOl2rtp21XD413tUy525W-usaYaGPb6unv5q3CvmKjhMVvNULUWGABEFg8966O_5vPw0pZ/pub" target="_blank" rel="noopener">→ View resume</a></p>

  <div class="section-label">Experience</div>

  <div class="resume-block">
    <h2>Crowdr</h2>
    <div class="resume-sub">Primary Backend Engineer · Remote</div>
    <ul>
      <li>Own the backend for a crowdfunding platform — payments, recurring donations, fraud detection, and observability.</li>
      <li>Rebuilt recurring billing from a cron sweep to a per-record delayed job model on BullMQ.</li>
      <li>Diagnosed and fixed a BudPay payout pipeline failure spanning provider routing and webhook signature verification.</li>
      <li>Built a custom marketing email system on AWS SES, guest donor magic-link auth, and 2FA for admin accounts.</li>
    </ul>
  </div>

  <div class="resume-block">
    <h2>Baaraku</h2>
    <div class="resume-sub">Backend Engineer · Remote</div>
    <ul>
      <li>Built a multi-tenant SaaS staffing platform from scratch with NestJS, Prisma, PostgreSQL, and Redis/BullMQ.</li>
      <li>Shipped a Chrome Manifest V3 extension for time tracking with idle detection and heartbeat survival.</li>
      <li>Designed a two-tier Trust/Verified timesheet model and an early-payout fee system on live FX rates.</li>
    </ul>
  </div>

  <div class="resume-block">
    <h2>Audease</h2>
    <div class="resume-sub">Backend Engineer · UK-based EdTech</div>
    <ul>
      <li>Built a Student Information Management System using NestJS and PostgreSQL.</li>
    </ul>
  </div>

  <div class="section-label">Education &amp; Training</div>

  <div class="resume-block">
    <h2>Moniepoint DreamDevs Bootcamp</h2>
    <div class="resume-sub">2026</div>
    <ul>
      <li>Capstone: CareRound, a multi-tenant hospital ward management SaaS in Java 21 / Spring Boot / Kafka, using the transactional outbox pattern. Deployed to EC2 with Docker Compose.</li>
    </ul>
  </div>

  <div class="resume-block">
    <h2>Babcock University</h2>
    <div class="resume-sub">B.Sc. Information Technology · GPA 4.21/5.0</div>
    <ul>
      <li>Published research on Ethereum-based academic credential verification in the ADCAIJ journal.</li>
    </ul>
  </div>

  <div class="section-label">Stack</div>
  <p style="font-family: var(--mono); font-size: 13px; color: var(--muted);">TypeScript · NestJS · Java · Spring Boot · PostgreSQL · MongoDB · Redis · BullMQ · Kafka · AWS SES · Docker</p>
</BaseLayout>
