---
import BaseLayout from '../layouts/BaseLayout.astro';
import Entry from '../components/Entry.astro';
import { getCollection, render } from 'astro:content';

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(featured.map((entry) => render(entry)));
---

<BaseLayout
  title="Teslim — Backend Engineer"
  description="Teslim is a backend engineer building payments and fintech infrastructure out of Lagos, Nigeria."
  active="me"
>
  <h1>Teslim</h1>
  <p class="role">Backend Engineer — Distributed Systems &amp; Fintech Infrastructure</p>

  <p>I build backend systems where the failure modes actually matter: async pipelines that can't drop events, payment flows that can't double-charge someone, multi-tenant platforms where one tenant's data has no business touching another's. I've carried that same discipline across fintech, SaaS, healthcare, and AI products — the domain keeps changing, the standards don't.</p>

  <p>My primary stack is TypeScript and NestJS. Java and Spring Boot when the problem calls for it. I tend to own the full backend: schema design through deployment, observability, and the CI/CD that catches things before users do. I write about what I build partly to document my thinking, partly because someone else is probably stuck on the same problem.</p>

  <p>Outside of work: football, basketball, technical reading, playing games, and slowly working through a backlog of system design books I keep promising myself I'll finish.</p>

  <div class="links-row">
    <a href="https://github.com/Tes-program" target="_blank" rel="noopener">GitHub</a>
    <a href="https://www.linkedin.com/in/teslim-odumuyiwa-154207182/" target="_blank" rel="noopener">LinkedIn</a>
    <a href="mailto:teslimodumuyiwa@gmail.com">Email</a>
  </div>

  <div class="section-label">Recently shipped</div>

  {featured.map((entry, i) => {
    const { Content } = rendered[i];
    return (
      <Entry
        hash={entry.data.hash}
        title={entry.data.title}
        context={entry.data.context}
        dateRange={entry.data.dateRange}
        tags={entry.data.tags}
        link={entry.data.link}
        linkLabel={entry.data.linkLabel}
        status={entry.data.status}
      >
        <Content />
      </Entry>
    );
  })}

  <p style="margin-top:24px;"><a href="/projects/" class="entry-link">→ all projects</a></p>
</BaseLayout>
